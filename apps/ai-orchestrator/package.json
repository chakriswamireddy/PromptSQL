{
  "name": "@platform/ai-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 9 — AI PAP Graph: natural-language policy authoring via LangGraph",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern='src/__tests__/unit'",
    "test:integration": "jest --testPathPattern='src/__tests__/integration' --runInBand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@langchain/langgraph": "^0.1.0",
    "@langchain/core": "^0.2.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.50.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.50.0",
    "@opentelemetry/instrumentation-fastify": "^0.37.0",
    "@opentelemetry/sdk-metrics": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.50.0",
    "@opentelemetry/resources": "^1.24.0",
    "@opentelemetry/semantic-conventions": "^1.24.0",
    "@platform/audit-client": "workspace:*",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.1",
    "kafkajs": "^2.2.4",
    "openai": "^4.47.1",
    "pg": "^8.11.5",
    "prom-client": "^15.1.0",
    "redis": "^4.6.14",
    "unleash-client": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
