# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=governance
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=127.0.0.1:9092

# ── ClickHouse ────────────────────────────────────────────────────────────
CLICKHOUSE_DSN=clickhouse://127.0.0.1:9100/audit

# ── MinIO / S3 ────────────────────────────────────────────────────────────
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AUDIT=audit-worm

# ── Qdrant ────────────────────────────────────────────────────────────────
QDRANT_URL=http://127.0.0.1:6333

# ── Vault ─────────────────────────────────────────────────────────────────
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root

# ── Unleash ───────────────────────────────────────────────────────────────
UNLEASH_URL=http://127.0.0.1:4242/api
UNLEASH_API_TOKEN=default:development.unleash-insecure-api-token

# ── OpenTelemetry ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_SERVICE_VERSION=local
DEPLOYMENT_ENVIRONMENT=local

# ── OIDC / Auth ───────────────────────────────────────────────────────────
OIDC_ISSUER=http://127.0.0.1:9080/realms/platform
OIDC_JWKS_URL=http://127.0.0.1:9080/realms/platform/protocol/openid-connect/certs
JWT_AUDIENCE=governance-platform
